# Copiar a .env y completar antes de levantar docker compose

# PostgreSQL
POSTGRES_USER=ftpcloud
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ftpcloud

# Backend
JWT_SIGNING_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
FRONTEND_ORIGIN=https://ftpcloud.dashclass.studio
SEED_OWNER_USERNAME=admin
SEED_OWNER_EMAIL=admin@example.com
SEED_OWNER_PASSWORD=changeme

# Frontend (build-time)
VITE_API_URL=https://apiftpcloud.dashclass.studio/api

# Cloudflare Tunnel (un solo token, las rutas por hostname se configuran en el dashboard)
CLOUDFLARE_TUNNEL_TOKEN=
